generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // 🔐 obrigatório agora
  name      String?
  image     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("users")
}

model Product {
  id     String  @id @default(uuid())
  name   String
  type   String
  brand  String?
  userId String

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}